{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ubion_Agent",
  "version": "0.1.0",
  "identifier": "com.ubion.agent",
  "build": {
    "devUrl": "http://localhost:8803",
    "frontendDist": "../web/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Ubion 에이전트",
        "width": 1100,
        "height": 760,
        "minWidth": 720,
        "minHeight": 480,
        "decorations": true,
        "fullscreen": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis", "dmg", "app"],
    "category": "Productivity",
    "shortDescription": "Self-evolving AI agent (Ubion ax center)",
    "longDescription": "사내 사용자의 PC 에서 동작하는 자기진화 에이전트. 트레이 상주 + 임베디드 Python + Tauri 외피.",
    "publisher": "Ubion ax center",
    "homepage": "https://ubion.global",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "resources": [
      "python/**/*",
      "engine/**/*",
      "skills-bundle-optional/**/*"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": ["English", "Korean"],
        "compression": "lzma"
      }
    },
    "macOS": {
      "minimumSystemVersion": "11.0",
      "dmg": {
        "windowSize": { "width": 660, "height": 400 }
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEE1MjU4RUE3QjE2MUREMjQKUldRazNXR3hwNDRscGR2Ri9za1dXcUsyRXpsTlIrNFNvL0JGM2xYRWRiR3IyclhnaVFFOGpjaHgK",
      "endpoints": [
        "https://updates.ubion.global/v1/agent/{{target}}/{{arch}}/{{current_version}}"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
