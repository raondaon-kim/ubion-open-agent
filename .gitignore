# =====================================================================
# Secrets — never commit
# =====================================================================
.env
.env.local
*.env.local
**/.env

# Tauri auto-updater signing key (private). The .pub counterpart is
# embedded in tauri.conf.json and is fine to commit.
src-tauri/.tauri/
**/.tauri/

# =====================================================================
# Python
# =====================================================================
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
env/

# Python build artifacts (the top-level `build/` is also covered, but
# being explicit lets editors fold the rules clearly).
build/
dist/

# =====================================================================
# Node.js / Vite (web/)
# =====================================================================
node_modules/
web/dist/
web/.vite/

# =====================================================================
# Rust / Tauri (src-tauri/)
# =====================================================================
# Build output (always huge, regenerated by `cargo build`).
src-tauri/target/

# Generated Tauri capability schemas. Re-emitted by tauri-build on every
# `cargo build`, so committing them only creates churn.
src-tauri/gen/

# Bundled payload — re-created by scripts/build-payload.ps1:
#   * python/  ~95 MB python-build-standalone + deps
#   * engine/  snapshot of ../engine
src-tauri/python/
src-tauri/engine/

# python-build-standalone download cache (~21 MB tarball).
src-tauri/.payload-cache/

# NOTE: src-tauri/Cargo.lock IS committed (binary crate — pin deps for
# reproducible builds).

# =====================================================================
# Local agent state
# =====================================================================
# UBION_AGENT_HOME default location when the agent runs from the repo.
.ubion-agent/

# Reference checkout of upstream Hermes (large; only used for porting
# decisions — kept local).
.hermes-clone/

# =====================================================================
# Test / smoke / debug output
# =====================================================================
output/
tests/output/
**/*.log

# One-off API/curl probe payloads used while iterating; if you intend to
# keep one, rename it without `probe` in the path.
sandbox/*probe*.json
sandbox/*probe*.txt

# Phase 0 sandbox state — runtime artifacts only, source is in the repo.
sandbox/**/.usage.json
sandbox/**/logs/

# =====================================================================
# Editor / OS
# =====================================================================
.vscode/
.idea/
.cursor/
.claude/
.claude.json
*.swp
*.swo
.DS_Store
Thumbs.db
