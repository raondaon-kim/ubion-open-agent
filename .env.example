# Self-Evolving Agent Platform — environment variables
#
# Copy this file to `.env` in the same directory and fill in your key(s).
# `.env` is git-ignored. `.env.example` is committed so future contributors
# know what keys are expected.
#
# Loaded automatically by:
#   - `python -m engine.server`     (Unit 10 API server)
#   - `python -m engine.run_demo`   (Unit 2 curator smoke test)
# Falls back silently when python-dotenv isn't installed; the env vars
# still work if you set them in your shell directly.

# --- Anthropic (Claude) ---------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-replace-me

# Optional: default model when the request doesn't pin one.
# Recognised IDs (Phase 1): claude-opus-4-7, claude-sonnet-4-6,
# claude-haiku-4-5-20251001.
# ANTHROPIC_MODEL=claude-opus-4-7

# --- DeepSeek (Unit 13, 2026-05-13) ---------------------------------------
# Sign up at https://platform.deepseek.com/ to mint a key. The agent
# routes any model name starting with `deepseek-` through this client.
DEEPSEEK_API_KEY=sk-deepseek-replace-me

# Optional: default DeepSeek model. Recognised IDs:
#   deepseek-v4-flash   (default, 128K context)
#   deepseek-v4-pro
#   deepseek-chat       (deprecated 2026-07-24)
#   deepseek-reasoner   (deprecated 2026-07-24)
# DEEPSEEK_MODEL=deepseek-v4-flash

# --- API server (Unit 10) -------------------------------------------------
# 단일 포트 정책 (사용자 결정 2026-05-13):
#   사용자가 보는 진입점       = Vite dev 0.0.0.0:8803
#   내부 FastAPI 백엔드        = 127.0.0.1:9000  (loopback only)
# Vite proxy 가 /v1, /health 를 9000 으로 라우팅. CORS 고민 0 (같은 origin).
#
# 모바일 (같은 Wi-Fi): http://<PC LAN IP>:8803/
# 데스크탑:           http://localhost:8803/
# UBION_HOST=127.0.0.1
# UBION_PORT=9000
# Bearer auth — leave empty for local dev. Set a token to require
# `Authorization: Bearer <token>` on all /v1/* requests.
# UBION_API_TOKEN=

# --- Agent home / workspace (post-Unit 9) ---------------------------------
# Where the agent stores its persistent brain (skills, memory, sessions).
# Defaults to ~/.ubion-agent/ if unset.
# UBION_AGENT_HOME=

# The user's current work folder (poetry collection, codebase, etc.).
# The prompt builder reads HERMES.md / AGENTS.md / CLAUDE.md / .cursorrules
# from this directory. Defaults to cwd if unset.
# UBION_WORKSPACE=D:\poems\
